# Version control
.git
.gitignore

# Dependencies (installed inside the container)
**/node_modules

# Compiled outputs (rebuilt inside the container)
apps/*/dist
packages/*/dist

# Local databases
local.db
*.local.db

# Environment files
.env
apps/server/.env
apps/web/.env

# Editor / OS
.cursor
.vscode
.DS_Store

# Logs
pnpm-debug.log*

# Test / scripts (not needed at runtime)
scripts/
