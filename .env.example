# Copy to apps/server/.env and fill in values.
# Validated in packages/env/src/server.ts — see README.md for deployment notes.

# LibSQL: local file or Turso URL (e.g. libsql://...turso.io)
DATABASE_URL=file:./local.db

# Min 32 chars
BETTER_AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Public base URL of this API (where /api/auth and /trpc are served)
BETTER_AUTH_URL=http://localhost:3000

# Exact origin of the SPA (scheme + host + port)
CORS_ORIGIN=http://localhost:5173

# Query param token for POST /webhook?token=...
WEBHOOK_TOKEN=replace-with-a-long-random-token

# SMTP (Nodemailer) — example values suit Resend; swap for Gmail, Postmark, etc.
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxx
SMTP_FROM=onboarding@yourverifieddomain.com

# Optional: comma-separated sign-in allowlist. Omit or empty = any domain (fine for local dev).
# ALLOWED_EMAIL_DOMAINS=acme.com,acme.org

# Optional: development | production | test (defaults to development)
# NODE_ENV=development

# --- Web app (separate file: apps/web/.env) ---
# VITE_SERVER_URL=http://localhost:3000
