# Copy to apps/headless/.env — validated by packages/env/src/headless.ts
#
# Foundry webhook URL: POST http://localhost:3000/webhook?token=<WEBHOOK_TOKEN>
# Test: GET http://localhost:3000/test?token=<WEBHOOK_TOKEN>

# Required — secret query param for /webhook and /test
WEBHOOK_TOKEN=replace-with-a-long-random-token

# Required — comma-separated statuses (new_status must match to notify)
# Valid: draft, waiting_for_confirmation, quote_sent, waiting_for_materials,
#   in_queue, in_production, data_analysis, in_review, done, canceled
SUBSCRIBE_STATUSES=quote_sent,done,canceled

# Optional — comma-separated emails (omit or leave empty for email disabled)
EMAIL_RECIPIENTS=you@example.com

# Optional — comma-separated Slack incoming webhook URLs
# SLACK_WEBHOOK_URLS=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Required for email — SMTP (Nodemailer); example suits Resend
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxx
SMTP_FROM=onboarding@yourverifieddomain.com

# Optional — development | production | test
# NODE_ENV=development
